    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "socket.io": "^4.6.1",
    "axios": "^1.6.5",
    "winston": "^3.11.0",
    "amadeus": "^9.0.0",
    "paystack": "^2.0.1",
